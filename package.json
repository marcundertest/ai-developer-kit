{
  "name": "integrity-suite",
  "version": "1.4.67",
  "type": "module",
  "description": "Strict project template for automated setup and code quality.",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js || echo 'No entry point configured'",
    "test:meta": "vitest run .integrity-suite/tests --reporter=verbose",
    "test:unit": "echo 'no unit tests'",
    "test:e2e": "echo 'no e2e tests'",
    "test:full": "INTEGRITY_SUITE_STRICT=true bash -c 'eslint . --max-warnings 0 && markdownlint . && prettier --check . && tsc --noEmit && pnpm test:meta && pnpm test:unit && pnpm test:e2e'",
    "test:develop": "INTEGRITY_SUITE_DEVELOPMENT=true pnpm test:full",
    "test:report": "node .integrity-suite/scripts/generate-report.js",
    "prepare": "husky"
  },
  "author": "Marc Galindo (marcundertest) - https://marcundertest.com",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint --fix",
      "prettier --write"
    ],
    "*.{js,json,css}": [
      "prettier --write"
    ]
  }
}
